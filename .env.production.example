POSTGRES_DB=obe_bot
POSTGRES_USER=obe_user
POSTGRES_PASSWORD=replace_me_postgres_password

SENDGRID_API_KEY=replace_with_real_sendgrid_api_key
EMAIL_FROM=jojgame10@gmail.com
LEADS_NOTIFY_TO=jojgame10@gmail.com

IG_WEBHOOK_VERIFY_TOKEN=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
WHATSAPP_ACCESS_TOKEN=replace_with_real_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_APP_SECRET=replace_me
HANDOFF_NOTIFY_TO=replace_with_notification_email

RAG_ENABLED=false
RAG_PUBLIC_ENABLED=false
RAG_PUBLIC_MIN_CONFIDENCE=0.55
RAG_PUBLIC_TOP_K=5
RAG_PUBLIC_MAX_CONTEXT_CHARS=6000
RAG_LLM_TEMPERATURE=0.25
RAG_LLM_TOP_P=0.9
RAG_LLM_REPEAT_PENALTY=1.08
